<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quickhire.ui.MasterController"
      stylesheets="@../css/styles.css" prefWidth="1000" prefHeight="660">

    <VBox fx:id="sidebarContainer" styleClass="sidebar"/>

    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: #F5F0E8; -fx-background: #F5F0E8;">
        <VBox style="-fx-background-color: #F5F0E8; -fx-padding: 28 32 28 32; -fx-spacing: 14;">

            <Label text="Post a New Job" styleClass="top-bar-title"/>

            <VBox styleClass="section-card" spacing="12">
                <Label text="Job Title *" styleClass="form-label"/>
                <TextField fx:id="titleField" promptText="e.g. House Cleaning"/>

                <Label text="Category *" styleClass="form-label"/>
                <ComboBox fx:id="categoryCombo" maxWidth="Infinity"/>

                <Label text="Location *" styleClass="form-label"/>
                <TextField fx:id="locationField" promptText="e.g. G-10, Islamabad"/>

                <Label text="Hourly Rate (PKR) *" styleClass="form-label"/>
                <TextField fx:id="hourlyRateField" promptText="e.g. 500"/>

                <Label text="Description *" styleClass="form-label"/>
                <TextArea fx:id="descriptionArea" promptText="Describe the work in detail..."
                          prefRowCount="5" wrapText="true"/>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <HBox spacing="12">
                    <Button text="Post Job" onAction="#handleSubmitPostJob" styleClass="btn-primary"/>
                    <Button text="Back to Dashboard" onAction="#handleBack" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
