<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.quickhire.ui.MasterController"
           stylesheets="@../css/styles.css"
           prefWidth="860" prefHeight="640"
           style="-fx-background-color: #F5F0E8;">

    <!-- Decorative circles -->
    <Circle radius="160" fill="transparent"
            stroke="#D8CEB8" strokeWidth="18" opacity="0.25"
            StackPane.alignment="TOP_RIGHT"
            translateX="80" translateY="-80"/>
    <Circle radius="130" fill="transparent"
            stroke="#D8CEB8" strokeWidth="15" opacity="0.18"
            StackPane.alignment="BOTTOM_LEFT"
            translateX="-60" translateY="60"/>

    <VBox alignment="CENTER" spacing="8">

        <Label text="QuickHire 🔗" styleClass="login-title"/>
        <Label text="Create Your Account" styleClass="login-subtitle"/>

        <VBox styleClass="login-card" spacing="12" maxWidth="420"
              style="-fx-translate-y: 12;">

            <Label text="Register" styleClass="login-heading"/>

            <Label text="Full Name" styleClass="form-label"/>
            <TextField fx:id="nameField" promptText="Your full name"/>

            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" promptText="your@email.com"/>

            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Min 6 characters"/>

            <Label text="I am a..." styleClass="form-label"/>
            <HBox spacing="24" alignment="CENTER_LEFT"
                  style="-fx-background-color: #FAF7F2; -fx-background-radius: 8;
                         -fx-padding: 10 14; -fx-border-color: #D8CEB8;
                         -fx-border-radius: 8;">
                <RadioButton fx:id="seekerRadio"   text="Job Seeker"   userData="SEEKER"
                             style="-fx-font-size: 13px; -fx-text-fill: #1B2B2B;"/>
                <RadioButton fx:id="providerRadio" text="Job Provider" userData="PROVIDER"
                             style="-fx-font-size: 13px; -fx-text-fill: #1B2B2B;"/>
            </HBox>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button text="Create Account" styleClass="btn-primary"
                    onAction="#handleRegister" maxWidth="Infinity"
                    style="-fx-padding: 12 0 12 0; -fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have an account?"
                       style="-fx-text-fill: #8A8A8A; -fx-font-size: 12px;"/>
                <Hyperlink text="Login" onAction="#goToLogin"
                           style="-fx-text-fill: #1B3A3A; -fx-font-size: 12px;
                                  -fx-font-weight: bold; -fx-underline: true;
                                  -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
