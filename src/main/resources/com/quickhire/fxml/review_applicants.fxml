<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quickhire.ui.MasterController"
      stylesheets="@../css/styles.css" prefWidth="1000" prefHeight="660">

    <VBox fx:id="sidebarContainer" styleClass="sidebar"/>

    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #F5F0E8; -fx-padding: 28 28 16 28; -fx-spacing: 14;">

        <Label text="Review Applicants" styleClass="top-bar-title"/>

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-card" style="-fx-padding: 12 16;">
            <Label text="Select your OPEN job:" styleClass="form-label"/>
            <ComboBox fx:id="jobCombo" prefWidth="320" promptText="-- select a job --"/>
        </HBox>

        <TableView fx:id="applicantsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol"   text="Seeker Name"      prefWidth="180"/>
                <TableColumn fx:id="ratingCol" text="Rating"           prefWidth="80"/>
                <TableColumn fx:id="noteCol"   text="Application Note" prefWidth="280"/>
                <TableColumn fx:id="dateCol"   text="Applied On"       prefWidth="150"/>
            </columns>
        </TableView>

        <Label fx:id="statusLabel" style="-fx-text-fill: #7A8A8A; -fx-font-size: 12px;"/>

        <HBox spacing="12">
            <Button text="Hire Selected Applicant" onAction="#handleHire"               styleClass="btn-primary"/>
            <Button text="View Seeker Reviews"     onAction="#handleViewSeekerReviews"  styleClass="btn-primary"/>
            <Button text="Back to Dashboard"       onAction="#handleBack"               styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</HBox>
