<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.quickhire.ui.MasterController"
           stylesheets="@../css/styles.css"
           prefWidth="860" prefHeight="600"
           style="-fx-background-color: #F5F0E8;">

    <!-- Decorative background chain link circles (top-right and bottom-left) -->
    <Circle radius="160" fill="transparent"
            stroke="#D8CEB8" strokeWidth="18" opacity="0.25"
            StackPane.alignment="TOP_RIGHT"
            translateX="80" translateY="-80"/>
    <Circle radius="100" fill="transparent"
            stroke="#D8CEB8" strokeWidth="12" opacity="0.20"
            StackPane.alignment="TOP_RIGHT"
            translateX="20" translateY="-20"/>
    <Circle radius="130" fill="transparent"
            stroke="#D8CEB8" strokeWidth="15" opacity="0.18"
            StackPane.alignment="BOTTOM_LEFT"
            translateX="-60" translateY="60"/>
    <Circle radius="80" fill="transparent"
            stroke="#D8CEB8" strokeWidth="10" opacity="0.15"
            StackPane.alignment="BOTTOM_LEFT"
            translateX="-10" translateY="10"/>

    <!-- Center content -->
    <VBox alignment="CENTER" spacing="8">

        <!-- Logo and tagline -->
        <Label text="QuickHire 🔗" styleClass="login-title"/>
        <Label text="Local Micro-Employment Hub" styleClass="login-subtitle"/>

        <!-- Login card -->
        <VBox styleClass="login-card" spacing="14" maxWidth="400"
              style="-fx-translate-y: 16;">

            <Label text="Sign In" styleClass="login-heading"/>

            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" promptText="your@email.com"/>

            <Label text="Password" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Password"/>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button fx:id="loginBtn" text="Login" styleClass="btn-primary"
                    onAction="#handleLogin" maxWidth="Infinity"
                    style="-fx-padding: 12 0 12 0; -fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="No account?" style="-fx-text-fill: #8A8A8A; -fx-font-size: 12px;"/>
                <Hyperlink fx:id="registerLink" text="Register here" onAction="#goToRegister"
                           style="-fx-text-fill: #1B3A3A; -fx-font-size: 12px;
                                  -fx-font-weight: bold; -fx-underline: true;
                                  -fx-border-color: transparent;"/>
            </HBox>
        </VBox>

    </VBox>
</StackPane>
