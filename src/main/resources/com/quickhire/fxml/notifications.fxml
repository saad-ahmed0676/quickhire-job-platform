<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quickhire.ui.MasterController"
      stylesheets="@../css/styles.css" prefWidth="1000" prefHeight="660">

    <VBox fx:id="sidebarContainer" styleClass="sidebar"/>

    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #F5F0E8; -fx-padding: 28 28 16 28; -fx-spacing: 14;">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="🔔  Notifications" styleClass="top-bar-title"/>
            <Label fx:id="unreadCountLabel"
                   style="-fx-background-color: #C0392B; -fx-text-fill: white;
                          -fx-background-radius: 12; -fx-padding: 3 10;
                          -fx-font-size: 11px; -fx-font-weight: bold;"
                   visible="false"/>
        </HBox>

        <ListView fx:id="notifList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <placeholder>
                <Label text="No notifications yet."
                       style="-fx-text-fill: #AAA; -fx-font-size: 13px;"/>
            </placeholder>
        </ListView>

        <HBox spacing="12">
            <Button text="🔄 Refresh"        onAction="#handleRefresh"    styleClass="btn-primary"/>
            <Button text="Mark All as Read"  onAction="#handleMarkAllRead" styleClass="btn-secondary"/>
            <Button text="Back to Dashboard" onAction="#handleBack"        styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</HBox>
