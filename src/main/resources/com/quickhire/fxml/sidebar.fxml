<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quickhire.ui.MasterController"
      styleClass="sidebar"
      stylesheets="@../css/styles.css">

    <!-- LOGO -->
    <Label text="QuickHire 🔗" styleClass="sidebar-logo"/>
    <Label text="Local Micro-Employment Hub" styleClass="sidebar-tagline"/>
    <Separator styleClass="sidebar-divider"/>

    <!-- MAIN -->
    <Label text="MAIN" styleClass="sidebar-section-label"/>

    <Button fx:id="btnDashboard" text="  ⬛  Dashboard"
            styleClass="nav-button" onAction="#handleDashboard" maxWidth="Infinity"/>

    <StackPane maxWidth="Infinity">
        <Button fx:id="btnNotifications" text="  🔔  Notifications"
                styleClass="nav-button" onAction="#handleNotifications" maxWidth="Infinity"/>
        <Label fx:id="notifBadge" text="●"
               style="-fx-text-fill: #E05050; -fx-font-size: 11px; -fx-padding: 0 10 16 0;"
               visible="false" StackPane.alignment="TOP_RIGHT"/>
    </StackPane>

    <!-- JOBS -->
    <Label text="JOBS" styleClass="sidebar-section-label"/>

    <!-- Seeker nav -->
    <VBox fx:id="seekerNav" managed="true" visible="true">
        <Button fx:id="btnFindJobs" text="  🔍  Find Jobs"
                styleClass="nav-button" onAction="#handleFindJobs" maxWidth="Infinity"/>
        <Button fx:id="btnUpdateProgress" text="  📋  Update Progress"
                styleClass="nav-button" onAction="#handleUpdateProgress" maxWidth="Infinity"/>
        <Button fx:id="btnCompleteJob" text="  ✅  Complete Job"
                styleClass="nav-button" onAction="#handleCompleteJob" maxWidth="Infinity"/>
    </VBox>

    <!-- Provider nav -->
    <VBox fx:id="providerNav" managed="false" visible="false">
        <Button fx:id="btnPostJob" text="  ➕  Post a Job"
                styleClass="nav-button" onAction="#handlePostJob" maxWidth="Infinity"/>
        <StackPane maxWidth="Infinity">
            <Button fx:id="btnReviewApplicants" text="  👥  Review Applicants"
                    styleClass="nav-button" onAction="#handleReviewApplicants" maxWidth="Infinity"/>
            <Label fx:id="applicantBadge" text="●"
                   style="-fx-text-fill: #E05050; -fx-font-size: 11px; -fx-padding: 0 10 16 0;"
                   visible="false" StackPane.alignment="TOP_RIGHT"/>
        </StackPane>
        <Button fx:id="btnManagePostings" text="  📁  Manage Postings"
                styleClass="nav-button" onAction="#handleManagePostings" maxWidth="Infinity"/>
        <Button fx:id="btnReviewInvoice" text="  🧾  Review Invoice"
                styleClass="nav-button" onAction="#handleReviewInvoice" maxWidth="Infinity"/>
    </VBox>

    <!-- ACCOUNT -->
    <Label text="ACCOUNT" styleClass="sidebar-section-label"/>
    <Button fx:id="btnRateReview" text="  ⭐  Rate &amp; Review"
            styleClass="nav-button" onAction="#handleRateReview" maxWidth="Infinity"/>
    <Button fx:id="btnProfile" text="  👤  My Profile"
            styleClass="nav-button" onAction="#handleProfile" maxWidth="Infinity"/>

    <Region VBox.vgrow="ALWAYS"/>
    <Separator styleClass="sidebar-divider"/>

    <!-- User info + avatar row -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding: 12 20 4 20;">
        <Label style="-fx-background-color: #C9A84C; -fx-background-radius: 50%;
                      -fx-min-width: 36px; -fx-min-height: 36px; -fx-max-width: 36px;
                      -fx-max-height: 36px; -fx-alignment: CENTER;
                      -fx-text-fill: #1B3A3A; -fx-font-weight: bold; -fx-font-size: 15px;"
               text="U" fx:id="avatarLabel"/>
        <VBox spacing="1">
            <Label fx:id="lblUserName" text="Loading..." styleClass="top-bar-user"/>
            <Label fx:id="lblUserRole" text="" styleClass="top-bar-role-badge"
                   style="-fx-background-color: transparent; -fx-text-fill: #C9A84C;
                          -fx-font-size: 11px; -fx-padding: 0;"/>
        </VBox>
    </HBox>

    <Button fx:id="btnLogout" text="  ⏻  Logout"
            styleClass="nav-button-logout" onAction="#handleLogout"
            maxWidth="Infinity" style="-fx-padding: 10 20 16 20;"/>

</VBox>
